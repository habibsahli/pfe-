# PostgreSQL
DATABASE_URL=postgresql://admin:SecurePassword123!@localhost:5432/fibre_forecast_db

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=fibre_forecast_rag

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_LLM_MODEL=llama3.1:8b

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=Fibre_Forecast
MLFLOW_ENABLE_REGISTRY=true

# Phoenix
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_ENABLE_TRACING=true

# Backend
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# Frontend
VITE_API_BASE_URL=http://localhost:8000

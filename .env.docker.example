# ============================================================================
# DOCKER ENVIRONMENT CONFIGURATION — EXAMPLE
# ============================================================================
# Copy this file to .env.docker and fill in your own values.
# Then update docker-compose.yml to reference these via env_file: .env.docker,
# or keep the inline environment: block in sync manually.
# ============================================================================

# PostgreSQL - uses Docker service name
DATABASE_URL=postgresql://admin:CHANGE_ME@postgres:5432/fibre_forecast_db

# Milvus Vector DB - uses Docker service name
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=fibre_forecast_rag

# Ollama LLM - uses Docker service name
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=300

# Generative forecasting (optional — leave empty to disable)
MOIRAI_API_URL=
MOIRAI_API_KEY=local

# MLflow - uses Docker service name
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=Fibre_Forecast
MLFLOW_ENABLE_REGISTRY=true

# Phoenix Tracing - uses Docker service name
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006
PHOENIX_ENABLE_TRACING=true

# Backend API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Frontend (server-side proxy target — used by next.config.mjs rewrites)
API_BASE_URL=http://fibre_backend:8000

# Frontend (browser-side — leave unset to auto-detect from window.location.hostname:8000)
# Set this to your host IP or domain when accessing from another machine:
# NEXT_PUBLIC_API_BASE_URL=http://192.168.x.x:8000

# RAG Configuration
RAG_DENSE_TOP_K=40
RAG_LEXICAL_TOP_K=40
RAG_FUSED_TOP_K=20
RAG_RRF_K=60
RAG_DENSE_WEIGHT=0.60
RAG_LEXICAL_WEIGHT=0.40
RAG_RERANK_OVERLAP_WEIGHT=0.20
